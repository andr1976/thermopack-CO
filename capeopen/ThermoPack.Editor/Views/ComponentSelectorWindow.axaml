<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:ThermoPack.Editor.ViewModels"
        x:Class="ThermoPack.Editor.Views.ComponentSelectorWindow"
        Title="ThermoPack - Select Components"
        Width="700" Height="500"
        WindowStartupLocation="CenterScreen">

  <!--
  <Design.DataContext>
    <vm:ComponentSelectorViewModel />
  </Design.DataContext>
  -->

  <Grid Margin="10" RowDefinitions="Auto,*,Auto" ColumnDefinitions="*,Auto,*">

    <!-- Search box -->
    <TextBox Grid.Row="0" Grid.Column="0"
             Watermark="Search components..."
             Text="{Binding SearchText}" />

    <TextBlock Grid.Row="0" Grid.Column="2"
               Text="Selected Components"
               VerticalAlignment="Center"
               FontWeight="Bold" />

    <!-- Available list -->
    <ListBox Grid.Row="1" Grid.Column="0"
             ItemsSource="{Binding FilteredAvailable}"
             SelectedItem="{Binding SelectedAvailable}"
             DoubleTapped="OnAddDouble">
      <ListBox.ItemTemplate>
        <DataTemplate>
          <StackPanel Orientation="Horizontal" Spacing="6">
            <TextBlock Text="{Binding Ident}" FontWeight="Bold" Width="50" />
            <TextBlock Text="{Binding Name}" />
            <TextBlock Text="{Binding Formula}" Foreground="Gray" />
          </StackPanel>
        </DataTemplate>
      </ListBox.ItemTemplate>
    </ListBox>

    <!-- Add/Remove buttons -->
    <StackPanel Grid.Row="1" Grid.Column="1"
                VerticalAlignment="Center" Spacing="6" Margin="6">
      <Button Content="Add &gt;" Click="OnAdd" Width="80" HorizontalContentAlignment="Center" />
      <Button Content="&lt; Remove" Click="OnRemove" Width="80" HorizontalContentAlignment="Center" />
    </StackPanel>

    <!-- Selected list -->
    <ListBox Grid.Row="1" Grid.Column="2"
             ItemsSource="{Binding SelectedComponents}"
             SelectedItem="{Binding SelectedChosen}"
             DoubleTapped="OnRemoveDouble">
      <ListBox.ItemTemplate>
        <DataTemplate>
          <StackPanel Orientation="Horizontal" Spacing="6">
            <TextBlock Text="{Binding Ident}" FontWeight="Bold" Width="50" />
            <TextBlock Text="{Binding Name}" />
          </StackPanel>
        </DataTemplate>
      </ListBox.ItemTemplate>
    </ListBox>

    <!-- OK / Cancel -->
    <StackPanel Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="3"
                Orientation="Horizontal" HorizontalAlignment="Right"
                Spacing="8" Margin="0,10,0,0">
      <Button Content="OK" Click="OnOk" Width="80" IsDefault="True" />
      <Button Content="Cancel" Click="OnCancel" Width="80" IsCancel="True" />
    </StackPanel>

  </Grid>
</Window>
